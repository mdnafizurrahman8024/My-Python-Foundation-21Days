elf.acc_no}\"\n","\n","\n","   def show_acc_balance(self): # getter method\n","     return f\"Account balance:{self.__balance}\"\n","\n","\n","  ## setter method\n","   def update_balance(self,amount):\n","     if amount>0:\n","      self.__balance +=amount\n","      print(f\"{amount} Tk deposited succesfully\")\n","     else:\n","      print(\"Invalid deposit amount\")\n","\n","  #abstractmethod\n","   @abstractmethod\n","   def withdraw(self,amount):\n","     pass\n","\n","\n","\n","  #### saving account- sub class\n","\n","class SavingAccount(Account):\n","   def withdraw(self,amount):\n","     if amount <=self.show_acc_balance():\n","        print(f\"{amount}Tk withdraw successfully\")\n","     else:\n","        print(\"insufficient balance\")\n","\n","\n"," ### current account- sub class\n","\n","class CurrentAccount(Account):\n","   def withdraw(self,amount):\n","     if amount<=self.show_acc_balance()+700: # overdraft limit 500\n","       print(f\"{amount} Tk withdraw successfully\")\n","     else:\n","       print(\"Overdraft limit exceeded\")\n","\n","  ## Object creation\n","\n","s1= SavingAccount(101,\"Zun\",7000)\n","c1= CurrentAccount(102,\"Zuni\",9000)\n","\n","s1.withdraw(5000)\n","c1.withdraw(6500)\n","c1.withdraw(7500)\n","\n"]},{"cell_type":"code","source":["from abc import ABC, abstractmethod   # Correct code\n","\n","class Account(ABC):\n","\n","    ### ---- Attributes -----\n","    def __init__(self, acc_no, acc_name, balance):\n","        self.acc_no = acc_no          # Public (no underscores)\n","        self._acc_name = acc_name     # Protected (one underscore)\n","        self.__balance = balance      # Private (two underscores)\n","\n","    ### ---- Methods ---------\n","\n","    # Public method\n","    def show_acc_no(self):\n","        return f\"Account number: {self.acc_no}\"\n","\n","    # Getter method (Returns just the NUMBER so we can do math with it later)\n","    def get_balance(self):\n","        return self.__balance\n","\n","    # Setter method (To update the private balance after a withdrawal)\n","    def set_balance(self, new_balance):\n","        self.__balance = new_balance\n","\n","    # Deposit method\n","    def update_balance(self, amount):\n","        if amount > 0:\n","            self.__balance += amount\n","            print(f\"{amount} Tk deposit successfully. New balance: {self.__balance}\")\n","        else:\n","            print(\"Invalid amount\")\n","\n","    # Abstract method\n","    @abstractmethod\n","    def withdraw(self, amount):\n","        pass\n","\n","\n","#### Saving Account - Sub Class\n","class SavingAccount(Account):\n","    def withdraw(self, amount):\n","        # Now we compare numbers using get_balance()\n","        if amount <= self.get_balance():\n","            # Actually deduct the money using the setter\n","            self.set_balance(self.get_balance() - amount)\n","            print(f\"{amount} Tk withdraw successfully. Remaining balance: {self.get_balance()}\")\n","        else:\n","            print(\"Insufficient balance\")\n","\n","\n","### Current Account - Sub Class\n","class CurrentAccount(Account):\n","    def withdraw(self, amount):\n","        # Overdraft limit 700\n","        if amount <= self.get_balance() + 700:\n","            self.set_balance(self.get_balance() - amount)\n","            print(f\"{amount} Tk withdraw successfully. Remaining balance: {self.get_balance()}\")\n","        else:\n","            print(\"Overdraft limit exceeded\")\n","\n","\n","# --- Object creation and Testing ---\n","\n","# Removed the underscores to match the exact Class names above\n","s1 = SavingAccount(101, \"Zun\", 7000)\n","c1 = CurrentAccount(102, \"Zuni\", 9000)\n","\n","s1.withdraw(5000)\n","c1.withdraw(6500)\n","c1.withdraw(7500)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"LkbuT5tdzPwh","executionInfo":{"status":"ok","timestamp":1783180011371,"user_tz":-360,"elapsed":56,"user":{"displayName":"Md Nafizur Rahman","userId":